# Пароль входа в админку /admin
ADMIN_PASSWORD=change-me
# Ключ подписи cookie-сессии (openssl rand -hex 32)
SECRET_KEY=change-me-too
# Поставьте 1 на проде за HTTPS: cookie сессии получит флаг Secure
COOKIE_SECURE=0
# IP, которым доступна админка (/admin, логин, изменение текстов), через запятую.
# Пусто = без ограничений. Префикс с точкой на конце разрешает подсеть: 10.0.
ADMIN_ALLOWED_IPS=
